{
  "name": "@vbt/db",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "studio": "prisma studio",
    "check-users": "tsx scripts/check-users.ts",
    "verify-users-schema": "tsx scripts/verify-users-schema.ts",
    "clean-neon": "tsx --env-file=.env prisma/scripts/clean-neon-keep-superadmin-and-partner.ts",
    "verify-neon": "tsx --env-file=.env prisma/scripts/verify-and-clean-neon.ts",
    "db:rebuild-core-business": "prisma db execute --file prisma/scripts/ensure-quote-status-enum.sql --schema prisma/schema.prisma && prisma db execute --file prisma/scripts/rebuild-core-business-tables.sql --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.10.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "xlsx": "^0.18.5"
  }
}
