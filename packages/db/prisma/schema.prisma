// ─────────────────────────────────────────────────────────────────────────────
// Partner SaaS (Vision Latam) – Multi-tenant schema
// Definitive ERD + gap fixes. See docs/ERD-GAP-ANALYSIS.md.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output        = "../../../apps/web/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OrganizationType {
  vision_latam
  commercial_partner
  master_partner
  internal
}

enum OrgMemberRole {
  org_admin
  sales_user
  technical_user
  viewer
}

enum OrgMemberStatus {
  active
  inactive
  invited
  suspended
}

enum PartnerType {
  commercial_partner
  master_partner
}

enum TerritoryType {
  exclusive
  open
  referral
}

enum ClientType {
  developer
  builder
  architect
  government
  end_client
}

enum ProjectStatus {
  lead
  qualified
  quoting
  engineering
  won
  lost
  on_hold
}

enum ProjectClaimStatus {
  pending
  approved
  rejected
  expired
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum QuoteItemType {
  product
  service
  other
}

enum InventoryTransactionType {
  purchase_in
  sale_out
  project_consumption
  project_surplus
  adjustment_in
  adjustment_out
  transfer_in
  transfer_out
}

enum EngineeringRequestStatus {
  draft
  submitted
  in_review
  pending_info
  needs_info
  in_progress
  completed
  delivered
  rejected
}

enum DocumentVisibility {
  public
  partners_only
  internal
}

enum EngineeringFeeMode {
  fixed
  percent
  per_request
  included
}

enum TrainingEnrollmentStatus {
  not_started
  in_progress
  completed
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  fullName             String    @map("full_name")
  email                String    @unique
  passwordHash         String    @map("password_hash")
  phone                String?
  isActive             Boolean   @default(true) @map("is_active")
  isPlatformSuperadmin Boolean   @default(false) @map("is_platform_superadmin")
  emailVerified        DateTime? @map("email_verified")
  image                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  lastLoginAt          DateTime? @map("last_login_at")

  orgMembers              OrgMember[]
  projectsAssigned        Project[]              @relation("ProjectAssignedTo")
  quotesPrepared          Quote[]                 @relation("QuotePreparedBy")
  quotesApproved          Quote[]                 @relation("QuoteApprovedBy")
  engineeringRequestsReq  EngineeringRequest[]    @relation("EngineeringRequestedBy")
  engineeringRequestsAss  EngineeringRequest[]    @relation("EngineeringAssignedTo")
  engineeringFiles        EngineeringFile[]
  engineeringDeliverables EngineeringDeliverable[]
  documentsCreated        Document[]              @relation("DocumentCreatedBy")
  trainingEnrollments     TrainingEnrollment[]
  activityLogs            ActivityLog[]
  invitedOrgMembers       OrgMember[]             @relation("InvitedBy")
  approvedProjectClaims   ProjectClaim[]
  passwordResetTokens     PasswordResetToken[]
  inventoryTransactionsCreated InventoryTransaction[] @relation("InventoryCreatedBy")

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Organizations ───────────────────────────────────────────────────────────

model Organization {
  id               String             @id @default(cuid())
  name             String
  legalName        String?            @map("legal_name")
  organizationType OrganizationType  @map("organization_type")
  countryCode      String?            @map("country_code")
  taxId            String?            @map("tax_id")
  email            String?
  phone            String?
  website          String?
  address          String?
  city             String?
  state            String?
  status           String             @default("active") // active, suspended, etc.
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  members             OrgMember[]
  partnerProfile      PartnerProfile?
  partnerInvites      PartnerInvite[]
  territories         PartnerTerritory[]
  clients             Client[]
  projects            Project[]
  projectClaims       ProjectClaim[]           @relation("ClaimingOrganization")
  quotes              Quote[]
  engineeringRequests EngineeringRequest[]
  trainingEnrollments  TrainingEnrollment[]
  activityLogs        ActivityLog[]
  warehouses          Warehouse[]
  freightProfiles     FreightProfile[]
  taxRuleSets         TaxRuleSet[]
  inventoryTransactions InventoryTransaction[]

  @@index([organizationType])
  @@index([status])
  @@map("organizations")
}

// ─── Warehouses (per-organization, for partner and superadmin inventory) ──────

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  location       String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryLevels      InventoryLevel[]
  inventoryTransactions InventoryTransaction[]

  @@index([organizationId])
  @@map("warehouses")
}

// ─── Inventory levels (stock per warehouse per catalog piece) ──────────────────

model InventoryLevel {
  id             String   @id @default(cuid())
  warehouseId    String   @map("warehouse_id")
  catalogPieceId String   @map("catalog_piece_id")
  quantity       Float    @default(0)
  unit           String?  // e.g. m2, m, units
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  catalogPiece CatalogPiece @relation(fields: [catalogPieceId], references: [id], onDelete: Restrict)

  @@unique([warehouseId, catalogPieceId])
  @@index([warehouseId])
  @@index([catalogPieceId])
  @@map("inventory_levels")
}

// ─── Inventory transactions (audit trail; each updates inventory_levels) ──────

model InventoryTransaction {
  id                String                  @id @default(cuid())
  warehouseId       String                  @map("warehouse_id")
  catalogPieceId    String                  @map("catalog_piece_id")
  quantityDelta     Float                   @map("quantity_delta")
  type              InventoryTransactionType @map("type")
  referenceQuoteId  String?                 @map("reference_quote_id")
  referenceProjectId String?                @map("reference_project_id")
  notes             String?
  createdByUserId   String?                 @map("created_by_user_id")
  organizationId    String                  @map("organization_id")
  createdAt         DateTime                @default(now()) @map("created_at")

  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  catalogPiece CatalogPiece @relation(fields: [catalogPieceId], references: [id], onDelete: Restrict)
  referenceQuote   Quote?   @relation(fields: [referenceQuoteId], references: [id], onDelete: SetNull)
  referenceProject Project? @relation(fields: [referenceProjectId], references: [id], onDelete: SetNull)
  createdByUser    User?    @relation("InventoryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([warehouseId])
  @@index([catalogPieceId])
  @@index([referenceQuoteId])
  @@index([referenceProjectId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ─── Org Members ─────────────────────────────────────────────────────────────

model OrgMember {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  userId         String          @map("user_id")
  role           OrgMemberRole   @default(viewer)
  status         OrgMemberStatus @default(active)
  invitedByUserId String?        @map("invited_by_user_id")
  joinedAt       DateTime?       @map("joined_at")
  lastActiveAt   DateTime?       @map("last_active_at")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("org_members")
}

// ─── Partner Profile ─────────────────────────────────────────────────────────

model PartnerProfile {
  id                    String    @id @default(cuid())
  organizationId        String    @unique @map("organization_id")
  contactName           String?   @map("contact_name")
  contactEmail          String?   @map("contact_email")
  partnerType           PartnerType @map("partner_type")
  territoryMode         String?   @map("territory_mode") // e.g. exclusive, multi
  onboardingState       String?   @map("onboarding_state") // application_received, agreement_signed, training_started, training_completed, active
  entryFeeUsd           Float?    @map("entry_fee_usd")
  trainingFeeUsd       Float?    @map("training_fee_usd")
  materialCreditUsd     Float?    @map("material_credit_usd")
  engineeringFeeMode    EngineeringFeeMode? @map("engineering_fee_mode")
  engineeringFeeValue   Float?    @map("engineering_fee_value")
  marginMinPct          Float?    @map("margin_min_pct")
  marginMaxPct          Float?    @map("margin_max_pct")
  minimumPricePolicy    String?   @map("minimum_price_policy")
  salesTargetAnnualUsd  Float?    @map("sales_target_annual_usd")
  salesTargetAnnualM2   Float?    @map("sales_target_annual_m2")
  agreementStartDate    DateTime? @map("agreement_start_date")
  agreementEndDate      DateTime? @map("agreement_end_date")
  agreementStatus       String?   @map("agreement_status")
  visionLatamCommissionPct Float? @map("vision_latam_commission_pct")
  visionLatamCommissionFixedUsd Float? @map("vision_latam_commission_fixed_usd")
  moduleVisibility       Json?    @map("module_visibility") // override per partner; keys e.g. engineering, documents, training, reports
  enabledSystems         Json?    @map("enabled_systems")   // ["S80","S150","S200"] — which panel systems this partner can use; null = all
  quoteDefaults         Json?    @map("quote_defaults")    // partner's defaults: { minRunFt?, commissionPct?, commissionFixed?, baseUom?, weightUom? }
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("partner_profiles")
}

// ─── Partner invite (pending signup) ───────────────────────────────────────────
// When inviting someone who doesn't have an account: store token, send email with
// link to /invite/accept?token=xxx so they can create account and join the org.

model PartnerInvite {
  id             String   @id @default(cuid())
  email          String
  organizationId  String   @map("organization_id")
  role           String   // owner, admin, sales, engineer, viewer
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@map("partner_invites")
}

// ─── Territories ─────────────────────────────────────────────────────────────

model PartnerTerritory {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  countryCode    String        @map("country_code")
  region         String?
  city           String?
  territoryType  TerritoryType @map("territory_type")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([countryCode])
  @@map("partner_territories")
}

// ─── Clients ─────────────────────────────────────────────────────────────────

model Client {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  name           String
  clientType     ClientType @map("client_type")
  countryCode    String?    @map("country_code")
  city           String?
  website        String?
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  projects     Project[]

  @@index([organizationId])
  @@index([clientType])
  @@map("clients")
}

// ─── Contacts ───────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  fullName  String   @map("full_name")
  email     String?
  phone     String?
  jobTitle  String?  @map("job_title")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("contacts")
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id                     String        @id @default(cuid())
  organizationId         String        @map("organization_id")
  clientId               String?       @map("client_id")
  projectName            String        @map("project_name")
  projectCode            String?       @map("project_code")
  countryCode            String?       @map("country_code")
  city                   String?
  address                String?
  projectType            String?       @map("project_type")
  status                 ProjectStatus @default(lead)
  estimatedTotalAreaM2   Float?        @map("estimated_total_area_m2")
  estimatedWallAreaM2    Float?        @map("estimated_wall_area_m2")
  estimatedUnits         Int?          @map("estimated_units")
  wallHeightM            Float?        @map("wall_height_m")
  description            String?
  competitionNotes       String?       @map("competition_notes")
  probabilityPct         Float?        @map("probability_pct")
  expectedCloseDate      DateTime?     @map("expected_close_date")
  assignedToUserId       String?       @map("assigned_to_user_id")
  isProjectProtected     Boolean       @default(false) @map("is_project_protected")
  projectProtectionUntil DateTime?     @map("project_protection_until")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                Client?               @relation(fields: [clientId], references: [id])
  assignedToUser        User?                 @relation("ProjectAssignedTo", fields: [assignedToUserId], references: [id])
  claims                ProjectClaim[]
  quotes                Quote[]
  engineeringRequests   EngineeringRequest[]
  inventoryTransactions InventoryTransaction[]

  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([assignedToUserId])
  @@map("projects")
}

// ─── Project Claims ─────────────────────────────────────────────────────────

model ProjectClaim {
  id                     String            @id @default(cuid())
  projectId              String            @map("project_id")
  claimingOrganizationId String            @map("claiming_organization_id")
  status                 ProjectClaimStatus @default(pending)
  approvedByUserId       String?           @map("approved_by_user_id")
  claimStartDate         DateTime?         @map("claim_start_date")
  claimEndDate           DateTime?         @map("claim_end_date")
  notes                  String?
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation("ClaimingOrganization", fields: [claimingOrganizationId], references: [id], onDelete: Cascade)
  approvedBy User?       @relation(fields: [approvedByUserId], references: [id])

  @@index([projectId])
  @@index([claimingOrganizationId])
  @@index([status])
  @@map("project_claims")
}

// ─── Quotes ──────────────────────────────────────────────────────────────────

model Quote {
  id                    String    @id @default(cuid())
  organizationId        String    @map("organization_id")
  projectId             String    @map("project_id")
  quoteNumber           String    @map("quote_number")
  version               Int       @default(1)
  status                QuoteStatus @default(draft)
  currency              String    @default("USD")
  factoryCostTotal      Float     @default(0) @map("factory_cost_total")
  visionLatamMarkupPct  Float     @default(0) @map("vision_latam_markup_pct")
  partnerMarkupPct      Float     @default(0) @map("partner_markup_pct")
  logisticsCost         Float     @default(0) @map("logistics_cost")
  importCost            Float     @default(0) @map("import_cost")
  localTransportCost    Float     @default(0) @map("local_transport_cost")
  technicalServiceCost  Float     @default(0) @map("technical_service_cost")
  totalPrice            Float     @default(0) @map("total_price")
  validUntil            DateTime? @map("valid_until")
  preparedByUserId      String?   @map("prepared_by_user_id")
  approvedByUserId      String?   @map("approved_by_user_id")
  superadminComment     String?   @map("superadmin_comment")
  reviewedAt            DateTime? @map("reviewed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  preparedByUser User?        @relation("QuotePreparedBy", fields: [preparedByUserId], references: [id])
  approvedByUser User?        @relation("QuoteApprovedBy", fields: [approvedByUserId], references: [id])
  items          QuoteItem[]
  inventoryTransactions InventoryTransaction[]

  @@unique([organizationId, quoteNumber, version])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("quotes")
}

// ─── Quote Items ─────────────────────────────────────────────────────────────

model QuoteItem {
  id             String       @id @default(cuid())
  quoteId        String       @map("quote_id")
  catalogPieceId String?      @map("catalog_piece_id")
  itemType      QuoteItemType @map("item_type")
  sku           String?
  description   String?
  unit          String?
  quantity      Float        @default(0)
  unitCost      Float        @default(0) @map("unit_cost")
  markupPct     Float        @default(0) @map("markup_pct")
  unitPrice     Float        @default(0) @map("unit_price")
  totalPrice    Float        @default(0) @map("total_price")
  sortOrder     Int          @default(0) @map("sort_order")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  quote        Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  catalogPiece CatalogPiece? @relation(fields: [catalogPieceId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([catalogPieceId])
  @@map("quote_items")
}

// ─── Engineering Requests ────────────────────────────────────────────────────

model EngineeringRequest {
  id                   String                    @id @default(cuid())
  organizationId       String                    @map("organization_id")
  projectId            String                    @map("project_id")
  requestNumber        String                    @map("request_number")
  status               EngineeringRequestStatus  @default(submitted)
  requestedByUserId    String?                   @map("requested_by_user_id")
  assignedToUserId     String?                   @map("assigned_to_user_id")
  requestType          String?                   @map("request_type")
  wallAreaM2           Float?                    @map("wall_area_m2")
  systemType           String?                   @map("system_type")
  targetDeliveryDate   DateTime?                 @map("target_delivery_date")
  engineeringFeeValue   Float?                    @map("engineering_fee_value")
  notes                String?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedByUser User?                    @relation("EngineeringRequestedBy", fields: [requestedByUserId], references: [id])
  assignedToUser  User?                    @relation("EngineeringAssignedTo", fields: [assignedToUserId], references: [id])
  files          EngineeringFile[]
  deliverables   EngineeringDeliverable[]

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@map("engineering_requests")
}

// ─── Engineering Files ───────────────────────────────────────────────────────

model EngineeringFile {
  id                   String   @id @default(cuid())
  engineeringRequestId String   @map("engineering_request_id")
  fileName             String   @map("file_name")
  fileUrl              String   @map("file_url")
  fileType             String?  @map("file_type")
  fileSize             Int?     @map("file_size")
  uploadedByUserId     String?  @map("uploaded_by_user_id")
  createdAt            DateTime @default(now()) @map("created_at")

  engineeringRequest EngineeringRequest @relation(fields: [engineeringRequestId], references: [id], onDelete: Cascade)
  uploadedByUser      User?               @relation(fields: [uploadedByUserId], references: [id])

  @@index([engineeringRequestId])
  @@map("engineering_files")
}

// ─── Engineering Deliverables ─────────────────────────────────────────────────

model EngineeringDeliverable {
  id                   String   @id @default(cuid())
  engineeringRequestId String   @map("engineering_request_id")
  deliverableType      String   @map("deliverable_type")
  title                String?
  description          String?
  fileName             String   @map("file_name")
  fileUrl              String   @map("file_url")
  version              Int      @default(1)
  uploadedByUserId     String?  @map("uploaded_by_user_id")
  createdAt            DateTime @default(now()) @map("created_at")

  engineeringRequest EngineeringRequest @relation(fields: [engineeringRequestId], references: [id], onDelete: Cascade)
  uploadedByUser      User?               @relation(fields: [uploadedByUserId], references: [id])

  @@index([engineeringRequestId])
  @@map("engineering_deliverables")
}

// ─── Document Library ────────────────────────────────────────────────────────

model DocumentCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")

  documents Document[]

  @@map("document_categories")
}

model Document {
  id              String            @id @default(cuid())
  categoryId      String            @map("category_id")
  title           String
  description     String?
  documentType    String?           @map("document_type")
  fileUrl         String            @map("file_url")
  version         Int               @default(1)
  languageCode    String?           @map("language_code")
  countryScope   String?            @map("country_scope") // comma-separated or *
  visibility      DocumentVisibility @default(partners_only)
  publishedAt     DateTime?         @map("published_at")
  createdByUserId String?           @map("created_by_user_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  category   DocumentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdByUser User?          @relation("DocumentCreatedBy", fields: [createdByUserId], references: [id])

  @@index([categoryId])
  @@index([visibility])
  @@index([countryScope])
  @@map("documents")
}

// ─── Training ───────────────────────────────────────────────────────────────

model TrainingProgram {
  id            String   @id @default(cuid())
  title         String
  description   String?
  level         String?
  status        String   @default("active")
  durationHours Float?   @map("duration_hours")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  modules    TrainingModule[]
  enrollments TrainingEnrollment[]

  @@map("training_programs")
}

model TrainingModule {
  id                String   @id @default(cuid())
  trainingProgramId String   @map("training_program_id")
  title             String
  moduleType        String?  @map("module_type")
  contentUrl        String?  @map("content_url")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  trainingProgram TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)

  @@index([trainingProgramId])
  @@map("training_modules")
}

model TrainingEnrollment {
  id                String                    @id @default(cuid())
  organizationId    String                    @map("organization_id")
  userId            String                    @map("user_id")
  trainingProgramId String                    @map("training_program_id")
  status            TrainingEnrollmentStatus   @default(not_started)
  progressPct       Float                     @default(0) @map("progress_pct")
  startedAt         DateTime?                 @map("started_at")
  completedAt       DateTime?                 @map("completed_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingProgram TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, trainingProgramId])
  @@index([organizationId])
  @@index([userId])
  @@index([trainingProgramId])
  @@map("training_enrollments")
}

// ─── Activity Logs ───────────────────────────────────────────────────────────

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String?   @map("organization_id")
  userId         String?   @map("user_id")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  action         String
  metadataJson   Json?    @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Countries (platform-wide; only superadmin can add/edit) ──────────────────

model Country {
  id        String   @id @default(cuid())
  code      String   @unique // ISO 2-letter
  name      String
  currency  String?  @default("USD")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  freightProfiles FreightProfile[]
  taxRuleSets     TaxRuleSet[]

  @@map("countries")
}

// ─── Freight rates: platform base (org null) + partner overrides ─────────────
// Superadmin sets base; partners can add/edit their own if they don't use VL-quoted service.

model FreightProfile {
  id                  String    @id @default(cuid())
  organizationId      String?   @map("organization_id") // null = Vision Latam base; set = partner override
  name                String
  countryId           String    @map("country_id")
  freightPerContainer Float     @map("freight_per_container") // USD
  isDefault           Boolean   @default(false) @map("is_default")
  expiryDate          DateTime? @map("expiry_date")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  country      Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([countryId])
  @@map("freight_profiles")
}

// ─── Tax rule sets: platform base per country + partner overrides (% etc.) ────
// Superadmin sets base per country; partners can override the % if they want.

model TaxRuleSet {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id") // null = Vision Latam base; set = partner override
  name           String
  countryId      String   @map("country_id")
  rulesJson      Json     @map("rules_json") // [{ order, label, base, ratePct?, fixedAmount?, note? }]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  country      Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([countryId])
  @@map("tax_rule_sets")
}

// ─── Piece catalog (platform-wide; superadmin loads; partners see only enabled systems) ─

model CatalogPiece {
  id              String   @id @default(cuid())
  dieNumber       String?  @map("die_number")
  canonicalName   String   @map("canonical_name")
  systemCode      String   @map("system_code")   // S80 | S150 | S200
  usefulWidthMm   Float?   @map("useful_width_mm")
  lbsPerMCored    Float?   @map("lbs_per_m_cored")
  kgPerMCored     Float?   @map("kg_per_m_cored")   // kg per linear m cored; derived from lbs (×0.453592) if not set
  pricePerM2Cored Float?   @map("price_per_m2_cored") // factory cost USD/m² cored (wall area); not $/m linear
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  inventoryLevels      InventoryLevel[]
  inventoryTransactions InventoryTransaction[]
  quoteItems           QuoteItem[]

  @@unique([canonicalName, systemCode])
  @@index([systemCode])
  @@index([isActive])
  @@map("catalog_pieces")
}

// ─── Platform config (global defaults, superadmin only) ───────────────────────

model PlatformConfig {
  id         String   @id @default(cuid())
  configJson Json     @map("config_json")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}
